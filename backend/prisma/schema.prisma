generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Barbershop {
  id           String        @id @default(uuid())
  name         String
  slug         String        @unique // e.g. "barbearia-do-ze"
  logoUrl      String?
  phone        String?
  address      String?
  
  admins       Admin[]
  services     Service[]
  barbers      Barber[]
  appointments Appointment[]
  waitingList  WaitingList[]
  
  createdAt    DateTime      @default(now())
}

model Admin {
  id           String      @id @default(uuid())
  username     String      @unique
  password     String
  
  barbershop   Barbershop? @relation(fields: [barbershopId], references: [id])
  barbershopId String?
}

model Service {
  id           String      @id @default(uuid())
  name         String
  description  String?
  price        Float
  duration     Int         // in minutes
  
  barbershop   Barbershop  @relation(fields: [barbershopId], references: [id])
  barbershopId String

  appointments Appointment[]
  waitingList  WaitingList[]
}

model Barber {
  id               String        @id @default(uuid())
  name             String
  email            String
  googleCalendarId String?
  googleTokens     String?
  
  barbershop       Barbershop    @relation(fields: [barbershopId], references: [id])
  barbershopId     String

  appointments     Appointment[]
  schedules        WorkSchedule[]
  waitingList      WaitingList[]

  @@unique([email, barbershopId])
}

model WorkSchedule {
  id        String   @id @default(uuid())
  dayOfWeek Int      // 0 (Sunday) to 6 (Saturday)
  startTime String   // "09:00"
  endTime   String   // "18:00"
  isActive  Boolean  @default(true)
  
  barber    Barber   @relation(fields: [barberId], references: [id])
  barberId  String
}

model Customer {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String?
  googleId      String?  @unique
  phone         String   @unique
  address       String?  
  loyaltyPoints Int      @default(0)
  isRegistered  Boolean  @default(true) 
  appointments  Appointment[]
  waitingList   WaitingList[]
  createdAt     DateTime @default(now())
}

model Appointment {
  id            String   @id @default(uuid())
  customerName  String
  customerPhone String
  startTime     DateTime
  endTime       DateTime
  googleEventId String?
  status        String   @default("PENDING")

  barbershop    Barbershop @relation(fields: [barbershopId], references: [id])
  barbershopId  String

  service       Service @relation(fields: [serviceId], references: [id])
  serviceId     String

  barber        Barber @relation(fields: [barberId], references: [id])
  barberId      String

  customer      Customer? @relation(fields: [customerId], references: [id])
  customerId    String?

  rating        Rating?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WaitingList {
  id            String   @id @default(uuid())
  customerName  String
  customerPhone String
  startTime     DateTime

  barbershop    Barbershop @relation(fields: [barbershopId], references: [id])
  barbershopId  String

  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id])
  barberId      String
  barber        Barber   @relation(fields: [barberId], references: [id])
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  status        String    @default("WAITING")
  createdAt     DateTime @default(now())

  @@index([startTime, barberId])
}

model Rating {
  id            String      @id @default(uuid())
  score         Int         // 1-5
  comment       String?
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  appointmentId String      @unique
  createdAt     DateTime    @default(now())
}

model AnticipationNotification {
  id            String   @id @default(uuid())
  appointmentId String   
  slotId        String   
  sentAt        DateTime @default(now())

  @@unique([appointmentId, slotId])
}
